{
  "name": "bookmytable-server",
  "version": "1.0.0",
  "description": "BookMyTable REST API — Express, MongoDB, Cognito JWT, S3, SES",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:remove-restaurant": "node scripts/removeRestaurantsByName.js",
    "db:remove-demo-bookings": "node scripts/removeBookingsByScreenshotSpec.js",
    "db:clear-except-users-restaurants": "node scripts/clearDatabaseExceptUsersRestaurants.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ses": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1023.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwk-to-pem": "^2.0.7",
    "mongoose": "^8.8.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  }
}
